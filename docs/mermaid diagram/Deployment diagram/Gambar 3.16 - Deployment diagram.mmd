flowchart TB
    %% Deployment Diagram - Spark Stage Fashion Commerce
    %% Berbeda dari contoh PHP/MySQL: project ini memakai React/Vite di Vercel dan Supabase PostgreSQL.

    user[User Browser\nPelanggan / Admin / Owner]:::client

    subgraph vercel["Vercel Hosting"]
        direction TB
        spa[React + Vite SPA\nStatic assets, routing, UI components]:::app
        cdn[Vercel CDN / Edge Network]:::infra
    end

    subgraph supabase["Supabase Platform"]
        direction TB
        auth[Supabase Auth\nEmail/password session, JWT, role lookup]:::service
        postgres[(PostgreSQL Database\nprofiles, products, carts, orders, payments)]:::database
        storage[Supabase Storage\nProduct images, CMS assets]:::storage
        edge[Supabase Edge Functions\ncreate checkout, webhook, reconcile, pickup verify]:::service
    end

    subgraph doku["DOKU Payment Gateway"]
        direction TB
        checkout[DOKU Checkout Overlay / Payment Page]:::external
        webhook[DOKU Webhook / Status API]:::external
    end

    user -->|HTTPS request| cdn
    cdn --> spa
    spa -->|Supabase JS API| auth
    spa -->|Read/write via RLS| postgres
    spa -->|Load/upload assets| storage
    spa -->|Invoke functions| edge

    edge -->|Privileged DB operations| postgres
    edge -->|Create payment session| checkout
    checkout -->|Payment interaction| user
    webhook -->|Payment notification| edge
    edge -->|Update order/payment status| postgres
    edge -->|Generate/verify pickup code| postgres

    classDef client fill:#ffffff,stroke:#111111,stroke-width:1.5px,color:#111111;
    classDef app fill:#fffaf0,stroke:#8a6d3b,stroke-width:1.2px,color:#111111;
    classDef infra fill:#eef2ff,stroke:#4f46e5,stroke-width:1.2px,color:#111111;
    classDef service fill:#ecfdf5,stroke:#047857,stroke-width:1.2px,color:#111111;
    classDef database fill:#fef2f2,stroke:#b91c1c,stroke-width:1.2px,color:#111111;
    classDef storage fill:#f0f9ff,stroke:#0369a1,stroke-width:1.2px,color:#111111;
    classDef external fill:#f6f6f6,stroke:#666666,stroke-width:1.5px,stroke-dasharray:4 3,color:#111111;
